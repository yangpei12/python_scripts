# 复制为项目根目录的 .env，并改成真实值。docker compose 会自动读取同目录下的 .env。
# ============================================================================

# 必填：Django SECRET_KEY；生成方式：
#   python -c "import secrets;print(secrets.token_urlsafe(50))"
WORKORDER_SECRET_KEY=REPLACE_ME_WITH_A_LONG_RANDOM_STRING

# 允许的 Host 头（浏览器访问时的域名/IP），多个用逗号分隔
WORKORDER_ALLOWED_HOSTS=workorder.intra.example.com,10.0.0.5,localhost

# 若通过反向代理带 HTTPS，请列出允许 CSRF 的源（带协议）
# WORKORDER_CSRF_TRUSTED_ORIGINS=https://workorder.intra.example.com

# gunicorn worker 数，建议 2×CPU+1，小团队 2~4 足矣
WORKORDER_WORKERS=3
WORKORDER_TIMEOUT=120

# （可选）首次启动自动创建超级管理员；已存在同名账号则跳过
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-after-login
DJANGO_SUPERUSER_EMAIL=admin@example.com
