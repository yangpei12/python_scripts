# 生产环境变量模板。
# 部署时复制为 /etc/workorder.env 并改成真实值，systemd 单元会 EnvironmentFile= 读取。
# ==============================================================================

# 一定要换！生成办法：python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
WORKORDER_SECRET_KEY=REPLACE_ME_WITH_A_RANDOM_50_CHAR_STRING

# 关闭 DEBUG
WORKORDER_DEBUG=0

# 内网 IP 或内部域名，多个用逗号分隔
WORKORDER_ALLOWED_HOSTS=workorder.intra.example.com,10.0.0.5

# 若通过反向代理带有不同 host/端口，这里列出允许 CSRF 的源（带协议）
# WORKORDER_CSRF_TRUSTED_ORIGINS=http://workorder.intra.example.com

# SQLite 数据库文件：务必放本机磁盘，不能是 NFS
WORKORDER_DB_PATH=/var/lib/workorder/db.sqlite3

# 静态文件收集目录（nginx 会直接读它）
WORKORDER_STATIC_ROOT=/var/lib/workorder/static

# 附件上传目录：可以是 NFS 挂载点，确保 workorder 进程用户可读写
WORKORDER_MEDIA_ROOT=/mnt/nfs/workorder/media
